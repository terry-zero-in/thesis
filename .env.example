# Thesis environment variables — copy to .env.local and fill in values.
# NEVER commit .env.local. Secrets stay in your local secrets.txt.

# ────────────────────────────────────────────────
# App
# ────────────────────────────────────────────────
# Public origin used to construct magic-link redirect + Resend approval URLs.
# Local: http://localhost:3000  |  Prod: https://thesis.example.com
NEXT_PUBLIC_APP_URL=

# Set to "true" to use recorded fixtures instead of hitting live external APIs.
# Tests force this to "true". Production must be "false" (or unset).
NEXT_PUBLIC_USE_MOCK_DATA=

# ────────────────────────────────────────────────
# Supabase (Postgres + Auth)
# ────────────────────────────────────────────────
# Public URL + anon key — exposed to browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# ────────────────────────────────────────────────
# Market data + research providers
# ────────────────────────────────────────────────
POLYGON_API_KEY=
FMP_API_KEY=
MARKETAUX_API_KEY=
PERPLEXITY_API_KEY=

# SEC EDGAR identifies callers via User-Agent — no key, but required.
# Format: "<App Name> <Contact Name> <email>"
EDGAR_USER_AGENT=

# ────────────────────────────────────────────────
# LLM providers
# ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ────────────────────────────────────────────────
# Workflow engine
# ────────────────────────────────────────────────
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ────────────────────────────────────────────────
# Transactional email (approval links)
# ────────────────────────────────────────────────
RESEND_API_KEY=
